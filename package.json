{
  "name": "cli-models",
  "version": "0.0.0",
  "private": true,
  "description": "Interactive terminal experiment for representing iModels in a CLI app.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cli-model": "./dist/cli.js"
  },
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli.ts",
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx watch src/cli.ts",
    "test": "pnpm build && node --test \"dist/**/*.test.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@itwin/core-backend": "5.8.0",
    "@itwin/core-bentley": "5.8.0",
    "@itwin/core-common": "5.8.0",
    "@itwin/core-geometry": "5.8.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
